---
import Layout from '../layouts/Layout.astro';
import { SEMESTER_OPTIONS } from '../data/conversion-table';
import {
  DEFAULT_TITLE,
  OG_IMAGE_PATH,
  OG_IMAGE_ALT,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
} from '../config/site';
---

<Layout>
  <header class="premium-header sticky top-0 z-50">
    <div class="mx-auto flex max-w-2xl items-center justify-between px-5 py-4">
      <div class="flex items-center gap-3">
        <div class="premium-logo">
          <img
            src="/apple-touch-icon.png"
            alt=""
            width="36"
            height="36"
            class="premium-logo-image"
            decoding="async"
          />
        </div>
        <div>
          <p class="text-[11px] font-bold tracking-[0.14em] gold-text uppercase">529Cal</p>
          <p class="text-sm font-medium text-[#d4d0c8]">내신 환산 · 입결 조회</p>
        </div>
      </div>
      <span class="premium-badge hidden sm:inline-block">2028 대입 · 5등급제</span>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-5 py-8 sm:py-12">
    <h1 class="sr-only">{DEFAULT_TITLE}</h1>

    <div id="wizard" class="wizard">
      <div class="wizard-progress">
        <div class="wizard-progress-bar">
          <div id="wizard-progress-fill" class="wizard-progress-fill"></div>
        </div>
        <p id="wizard-step-label" class="wizard-step-label">1 / 4 · 이수 학기</p>
      </div>

      <!-- Step 1: Semester -->
      <section class="wizard-panel premium-card" data-step="1">
        <div class="p-6 sm:p-8">
          <h2 class="wizard-question">지금까지 몇 학기를 마쳤나요?</h2>
          <p class="wizard-hint">이수 완료 학기를 선택하면 환산 기준이 적용됩니다.</p>
          <div class="wizard-body">
            <div class="wizard-semester-grid" role="radiogroup" aria-label="이수 완료 학기 선택">
              {
                SEMESTER_OPTIONS.map((option) => (
                  <label class="semester-chip cursor-pointer">
                    <input
                      type="radio"
                      name="semester"
                      value={option.id}
                      class="sr-only semester-radio"
                      checked={option.id === 'g1s2'}
                    />
                    <span class="semester-chip-label">{option.label}</span>
                  </label>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <!-- Step 2: Grades -->
      <section class="wizard-panel premium-card hidden" data-step="2">
        <div class="p-6 sm:p-8">
          <h2 class="wizard-question">어떤 등급을 환산할까요?</h2>
          <p class="wizard-hint">변환 방향을 선택한 뒤, 해당 등급만 입력해 주세요.</p>

          <div class="wizard-body space-y-5">
            <div class="convert-mode-grid" role="radiogroup" aria-label="환산 방향 선택">
              <label class="convert-mode-chip cursor-pointer">
                <input type="radio" name="convert-mode" value="5to9" class="sr-only convert-mode-radio" checked />
                <span class="convert-mode-chip-inner">
                  <span class="convert-mode-badge">5 → 9</span>
                  <span class="convert-mode-title">5등급제를 9등급제로 변환하기</span>
                  <span class="convert-mode-desc">5등급제 평균을 입력하면 9등급제로 환산합니다</span>
                </span>
              </label>
              <label class="convert-mode-chip cursor-pointer">
                <input type="radio" name="convert-mode" value="9to5" class="sr-only convert-mode-radio" />
                <span class="convert-mode-chip-inner">
                  <span class="convert-mode-badge convert-mode-badge--9">9 → 5</span>
                  <span class="convert-mode-title">9등급제를 5등급제로 변환하기</span>
                  <span class="convert-mode-desc">9등급제 평균을 입력하면 5등급제로 환산합니다</span>
                </span>
              </label>
            </div>

            <div class="grade-field-slot">
              <div id="grade5-field" class="grade-field">
              <label for="grade5-input" class="label-premium mb-2 flex items-center gap-2">
                <span class="grade-badge grade-badge--5">5</span>
                5등급제 평균
              </label>
              <div class="grade-input-wrap">
                <input id="grade5-input" type="number" min="1" max="5" step="0.001" placeholder="평균 등급을 입력" class="input-grade is-active" />
                <div class="grade-stepper">
                  <button type="button" class="grade-step-btn" data-target="grade5-input" data-dir="up" aria-label="5등급 0.001 증가">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 15l-6-6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button type="button" class="grade-step-btn" data-target="grade5-input" data-dir="down" aria-label="5등급 0.001 감소">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>
              <p class="input-hint">범위 1.000 — 5.000</p>
            </div>

            <div id="grade9-field" class="grade-field hidden">
              <label for="grade9-input" class="label-premium mb-2 flex items-center gap-2">
                <span class="grade-badge grade-badge--9">9</span>
                9등급제 평균
              </label>
              <div class="grade-input-wrap">
                <input id="grade9-input" type="number" min="1" max="9" step="0.001" placeholder="평균 등급을 입력" class="input-grade is-active" />
                <div class="grade-stepper">
                  <button type="button" class="grade-step-btn" data-target="grade9-input" data-dir="up" aria-label="9등급 0.001 증가">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 15l-6-6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button type="button" class="grade-step-btn" data-target="grade9-input" data-dir="down" aria-label="9등급 0.001 감소">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>
              <p class="input-hint">범위 1.000 — 9.000</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Step 3: Results -->
      <section class="wizard-panel hidden" data-step="3">
        <div class="space-y-4">
          <div class="premium-card p-6 sm:p-8 text-center">
            <h2 class="wizard-question">환산 결과가 나왔어요!</h2>
            <p id="step3-hint" class="wizard-hint">입시에 활용할 수 있는 9등급제 환산값입니다.</p>
          </div>

          <div id="results-panel" class="result-panel animate-fade-up premium-card">
            <div class="p-6 sm:p-8">
              <div class="result-panel-header">
                <p class="result-panel-label">환산 결과</p>
                <span id="result-tier-badge" class="result-tier-badge">—</span>
              </div>
              <div class="result-hero">
                <div class="result-gauge" aria-hidden="true">
                  <svg class="result-gauge-svg" viewBox="0 0 128 128">
                    <defs>
                      <linearGradient id="gauge-gold-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#c9a030" />
                        <stop offset="50%" stop-color="#f0d88a" />
                        <stop offset="100%" stop-color="#fff4d0" />
                      </linearGradient>
                    </defs>
                    <circle class="result-gauge-track" cx="64" cy="64" r="54" />
                    <circle id="percentile-ring" class="result-gauge-fill" cx="64" cy="64" r="54" />
                  </svg>
                  <div class="result-gauge-center">
                    <span class="result-gauge-prefix">상위</span>
                    <span id="percentile-number" class="result-gauge-number">—</span>
                    <span class="result-gauge-suffix">%</span>
                  </div>
                </div>
                <div class="result-details">
                  <div class="result-metrics">
                    <div class="result-metric">
                      <span class="result-metric-badge">5</span>
                      <div>
                        <p class="result-metric-label">5등급제 환산</p>
                        <p id="result-grade5" class="result-metric-value">—</p>
                      </div>
                    </div>
                    <div class="result-metric">
                      <span class="result-metric-badge result-metric-badge--9">9</span>
                      <div>
                        <p class="result-metric-label">9등급제 환산</p>
                        <p id="result-grade9" class="result-metric-value">—</p>
                      </div>
                    </div>
                  </div>
                  <div class="result-bar-section">
                    <div class="result-bar-header">
                      <span>누적 백분위</span>
                      <span id="percentile-display" class="result-bar-caption">상위 —%</span>
                    </div>
                    <div class="result-bar-track">
                      <div id="percentile-bar" class="result-bar-fill"></div>
                      <div id="percentile-marker" class="result-bar-marker"></div>
                    </div>
                    <div class="result-bar-scale">
                      <span>상위 100%</span>
                      <span>상위 50%</span>
                      <span>상위 1%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-2 px-1">
            <div id="extrapolation-note" class="notice-warn hidden">
              <span>실측 데이터 범위를 벗어난 입력은 추세를 연장한 추정값이며, 정확도가 낮을 수 있습니다.</span>
            </div>
            <p class="notice-info">
              본 도구의 결과는 참고용 추정치입니다. 실제 입시 반영 방식과 차이가 있을 수 있습니다.
            </p>
          </div>

          <div class="wizard-actions">
            <button type="button" id="btn-download-card" class="wizard-btn wizard-btn--secondary">이미지 저장</button>
            <button type="button" id="btn-share-result" class="wizard-btn wizard-btn--secondary">결과 공유하기</button>
          </div>
        </div>
      </section>

      <!-- Step 4: Admission -->
      <section class="wizard-panel premium-card hidden" data-step="4">
        <div class="p-6 sm:p-8">
          <h2 class="wizard-question">관심 대학 합격 가능성 확인</h2>
          <p class="wizard-hint">입력하신 내신으로 21~25학년도 70% 컷과 비교합니다.</p>

          <div id="grade-summary-banner" class="grade-summary-banner wizard-body">
            <p class="grade-summary-title">내 내신 기준</p>
            <div class="grade-summary-stats">
              <span>5등급 <strong id="summary-grade5">—</strong></span>
              <span>9등급 <strong id="summary-grade9">—</strong></span>
              <span>백분위 <strong id="summary-percentile">—</strong></span>
            </div>
            <p class="grade-summary-desc">선택한 모집단위의 전형·세부전형별 70% 컷과 자동 비교됩니다.</p>
          </div>

          <p id="admission-loading" class="hidden text-sm text-[#d4d0c8]">입결 데이터 불러오는 중…</p>
          <p id="admission-error" class="hidden text-sm text-red-400"></p>

          <div id="admission-form" class="hidden space-y-5">
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <label for="admission-uni-input" class="label-premium block">대학</label>
                <div class="search-combobox">
                  <input id="admission-uni-input" type="text" class="search-input" placeholder="대학명 검색 (예: 고려, 연세)" autocomplete="off" spellcheck="false" />
                  <input type="hidden" id="admission-uni-value" />
                  <ul id="admission-uni-list" class="search-dropdown hidden" role="listbox"></ul>
                </div>
              </div>
              <div class="sm:col-span-2">
                <label for="admission-dept-input" class="label-premium block">모집단위</label>
                <div class="search-combobox">
                  <input id="admission-dept-input" type="text" class="search-input" placeholder="모집단위 검색 (예: 컴퓨터, 경영)" autocomplete="off" spellcheck="false" disabled />
                  <input type="hidden" id="admission-dept-value" />
                  <ul id="admission-dept-list" class="search-dropdown hidden" role="listbox"></ul>
                </div>
              </div>
            </div>

            <div id="admission-results" class="hidden space-y-5"></div>

            <p id="admission-empty" class="empty-state hidden">모집단위를 선택하면 전형·세부전형별 입결을 표시합니다.</p>
          </div>

          <div class="wizard-share-row wizard-actions">
            <button type="button" id="btn-share-admission" class="wizard-btn wizard-btn--secondary">
              친구에게 공유하기
            </button>
            <button type="button" id="btn-restart-wizard" class="wizard-btn wizard-btn--secondary">
              처음부터 계산하기
            </button>
          </div>
        </div>
      </section>

      <nav id="wizard-nav" class="wizard-nav wizard-nav--split" aria-label="단계 이동">
        <button type="button" id="wizard-prev" class="wizard-btn wizard-btn--secondary">← 이전</button>
        <button type="button" id="wizard-next" class="wizard-btn wizard-btn--primary">다음 →</button>
      </nav>
    </div>
  </main>

  <div id="wizard-toast" class="wizard-toast" role="status" aria-live="polite"></div>

  <footer class="premium-footer">
    <figure class="sr-only">
      <img
        src={OG_IMAGE_PATH}
        alt={OG_IMAGE_ALT}
        width={OG_IMAGE_WIDTH}
        height={OG_IMAGE_HEIGHT}
        decoding="async"
      />
    </figure>
    <p><span class="gold-text font-semibold">529Cal</span> · 내신 등급 환산 · 대학별 입결 조회</p>
    <p>교육 상담·입시 참고용 도구</p>
  </footer>
</Layout>

<script>
  import {
    DEFAULT_SEMESTER_ID,
    fromGrade5,
    fromGrade9,
    getSemesterOption,
    type SemesterOptionId,
  } from '../lib/grade-calculator';
  import type { AdmissionIndex, YearCut } from '../lib/admission-data';
  import { SearchCombobox } from '../lib/search-combobox';
  import { downloadCanvas, renderResultCardCanvas, shareCanvas } from '../lib/result-card';
  import {
    buildShareText,
    buildShareUrl,
    getStepLabel,
    parseWizardState,
    shareSite,
    type WizardStep,
  } from '../lib/wizard-flow';

  type ConversionResult = NonNullable<ReturnType<typeof fromGrade5>>;
  type AdmissionLib = typeof import('../lib/admission-data');

  let admissionLib: AdmissionLib | null = null;

  type ConversionMode = '5to9' | '9to5';
  let currentStep: WizardStep = 1;
  let lastResult: ConversionResult | null = null;
  let admissionData: AdmissionIndex | null = null;

  const grade5Input = document.getElementById('grade5-input') as HTMLInputElement;
  const grade9Input = document.getElementById('grade9-input') as HTMLInputElement;
  const percentileDisplay = document.getElementById('percentile-display')!;
  const percentileNumber = document.getElementById('percentile-number')!;
  const percentileRing = document.getElementById('percentile-ring')!;
  const percentileBar = document.getElementById('percentile-bar')!;
  const percentileMarker = document.getElementById('percentile-marker')!;
  const resultGrade5 = document.getElementById('result-grade5')!;
  const resultGrade9 = document.getElementById('result-grade9')!;
  const resultTierBadge = document.getElementById('result-tier-badge')!;
  const extrapolationNote = document.getElementById('extrapolation-note')!;
  const resultsPanel = document.getElementById('results-panel')!;
  const semesterRadios = document.querySelectorAll<HTMLInputElement>('.semester-radio');
  const gradeStepButtons = document.querySelectorAll<HTMLButtonElement>('.grade-step-btn');
  const convertModeRadios = document.querySelectorAll<HTMLInputElement>('.convert-mode-radio');
  const grade5Field = document.getElementById('grade5-field')!;
  const grade9Field = document.getElementById('grade9-field')!;
  const wizardPanels = document.querySelectorAll<HTMLElement>('.wizard-panel');
  const progressFill = document.getElementById('wizard-progress-fill')!;
  const stepLabel = document.getElementById('wizard-step-label')!;
  const step3Hint = document.getElementById('step3-hint')!;
  const toastEl = document.getElementById('wizard-toast')!;
  const summaryGrade5 = document.getElementById('summary-grade5')!;
  const summaryGrade9 = document.getElementById('summary-grade9')!;
  const summaryPercentile = document.getElementById('summary-percentile')!;
  const wizardNav = document.getElementById('wizard-nav')!;
  const wizardPrev = document.getElementById('wizard-prev') as HTMLButtonElement;
  const wizardNext = document.getElementById('wizard-next') as HTMLButtonElement;

  const loadingEl = document.getElementById('admission-loading')!;
  const errorEl = document.getElementById('admission-error')!;
  const formEl = document.getElementById('admission-form')!;
  const resultsEl = document.getElementById('admission-results')!;
  const emptyEl = document.getElementById('admission-empty')!;

  const uniCombobox = new SearchCombobox({
    input: document.getElementById('admission-uni-input') as HTMLInputElement,
    list: document.getElementById('admission-uni-list') as HTMLUListElement,
    hidden: document.getElementById('admission-uni-value') as HTMLInputElement,
    onChange: onUniChange,
  });

  const deptCombobox = new SearchCombobox({
    input: document.getElementById('admission-dept-input') as HTMLInputElement,
    list: document.getElementById('admission-dept-list') as HTMLUListElement,
    hidden: document.getElementById('admission-dept-value') as HTMLInputElement,
    onChange: renderAdmissionResults,
  });

  const GAUGE_RADIUS = 54;
  const GAUGE_CIRCUMFERENCE = 2 * Math.PI * GAUGE_RADIUS;
  const GRADE_STEP = 0.001;
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function showToast(message: string) {
    toastEl.textContent = message;
    toastEl.classList.add('is-visible');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toastEl.classList.remove('is-visible'), 2800);
  }

  function getPercentileTier(percentile: number): string {
    if (percentile <= 5) return '최상위권';
    if (percentile <= 30) return '상위권';
    if (percentile <= 40) return '중상위권';
    if (percentile <= 55) return '중위권';    
    if (percentile <= 70) return '중하위권';
    return '하위권';
  }

  function getSelectedSemester(): SemesterOptionId {
    const checked = document.querySelector<HTMLInputElement>('.semester-radio:checked');
    return (checked?.value as SemesterOptionId) ?? DEFAULT_SEMESTER_ID;
  }

  function getSemesterLabel(): string {
    return getSemesterOption(getSelectedSemester()).label;
  }

  function getCredits(): number {
    return getSemesterOption(getSelectedSemester()).credits;
  }

  function clampGrade(value: number, min: number, max: number): number {
    return Math.min(max, Math.max(min, value));
  }

  function formatGradeValue(input: HTMLInputElement, value: number): void {
    input.value = clampGrade(value, parseFloat(input.min), parseFloat(input.max)).toFixed(3);
  }

  function getConversionMode(): ConversionMode {
    const checked = document.querySelector<HTMLInputElement>('.convert-mode-radio:checked');
    return (checked?.value as ConversionMode) ?? '5to9';
  }

  function syncConversionModeUI() {
    const mode = getConversionMode();
    const is5to9 = mode === '5to9';
    grade5Field.classList.toggle('hidden', !is5to9);
    grade9Field.classList.toggle('hidden', is5to9);
    grade5Input.classList.toggle('is-active', is5to9);
    grade5Input.classList.toggle('is-inactive', !is5to9);
    grade9Input.classList.toggle('is-active', !is5to9);
    grade9Input.classList.toggle('is-inactive', is5to9);
    step3Hint.textContent = is5to9
      ? '입시에 활용할 수 있는 9등급제 환산값입니다.'
      : '입시에 활용할 수 있는 5등급제 환산값입니다.';
  }

  function applyResultToInputs(result: ConversionResult) {
    grade5Input.value = result.grade5.toFixed(3);
    grade9Input.value = result.grade9.toFixed(3);
  }

  function updateResultVisuals(result: ConversionResult) {
    const p = result.percentile;
    const pText = p.toFixed(3);
    percentileNumber.textContent = pText;
    percentileDisplay.textContent = `상위 ${pText}%`;
    resultGrade5.textContent = result.grade5.toFixed(3);
    resultGrade9.textContent = result.grade9.toFixed(3);
    resultTierBadge.textContent = getPercentileTier(p);
    const fillRatio = (100 - Math.min(100, Math.max(0, p))) / 100;
    percentileRing.style.strokeDasharray = `${GAUGE_CIRCUMFERENCE}`;
    percentileRing.style.strokeDashoffset = `${GAUGE_CIRCUMFERENCE * (1 - fillRatio)}`;
    percentileBar.style.width = `${fillRatio * 100}%`;
    percentileMarker.style.left = `${fillRatio * 100}%`;
  }

  function updateGradeSummary() {
    if (!lastResult) return;
    summaryGrade5.textContent = lastResult.grade5.toFixed(3);
    summaryGrade9.textContent = lastResult.grade9.toFixed(3);
    summaryPercentile.textContent = `상위 ${lastResult.percentile.toFixed(3)}%`;
  }

  function pulseResults() {
    resultsPanel.classList.remove('animate-fade-up');
    void resultsPanel.offsetWidth;
    resultsPanel.classList.add('animate-fade-up');
  }

  function computeResult(): ConversionResult | null {
    const credits = getCredits();
    const mode = getConversionMode();

    if (mode === '5to9') {
      const grade5Val = parseFloat(grade5Input.value);
      if (!Number.isFinite(grade5Val)) return null;
      return fromGrade5(grade5Val, credits);
    }

    const grade9Val = parseFloat(grade9Input.value);
    if (!Number.isFinite(grade9Val)) return null;
    return fromGrade9(grade9Val, credits);
  }

  function updateConverter() {
    if (currentStep < 3) {
      updateWizardNav();
      return;
    }

    const result = computeResult();
    if (!result) {
      lastResult = null;
      return;
    }
    lastResult = result;
    applyResultToInputs(result);
    updateResultVisuals(result);
    extrapolationNote.classList.toggle('hidden', !result.isExtrapolated);
    if (currentStep === 3) pulseResults();
    if (currentStep === 4) {
      updateGradeSummary();
      if (deptCombobox.getValue()) renderAdmissionResults();
    }
    updateWizardNav();
  }

  function syncUrl(step = currentStep) {
    if (step <= 1) {
      history.replaceState(null, '', window.location.pathname);
      return;
    }
    if (!lastResult && step > 2) return;
    const url = buildShareUrl({
      step,
      semester: getSelectedSemester(),
      grade5: grade5Input.value,
      grade9: grade9Input.value,
    });
    history.replaceState(null, '', url);
  }

  function canAdvanceFromStep2(): boolean {
    return computeResult() !== null;
  }

  function updateWizardNav() {
    wizardPrev.disabled = false;

    if (currentStep === 4) {
      wizardNext.hidden = true;
      wizardNav.classList.add('wizard-nav--prev-only');
      return;
    }

    wizardNext.hidden = false;
    wizardNav.classList.remove('wizard-nav--prev-only');
    wizardNext.disabled = currentStep === 2 && !canAdvanceFromStep2();

    if (currentStep === 1) wizardNext.textContent = '다음 →';
    else if (currentStep === 2) wizardNext.textContent = '결과 보기 →';
    else if (currentStep === 3) wizardNext.textContent = '입결 조회 →';
  }

  async function getAdmissionLib(): Promise<AdmissionLib> {
    return admissionLib ??= await import('../lib/admission-data');
  }

  async function ensureAdmissionData(): Promise<void> {
    if (admissionData && admissionLib) {
      loadingEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      formEl.classList.remove('hidden');
      emptyEl.classList.remove('hidden');
      return;
    }

    loadingEl.classList.remove('hidden');
    errorEl.classList.add('hidden');
    formEl.classList.add('hidden');

    try {
      const lib = await getAdmissionLib();
      const data = await lib.loadAdmissionIndex();
      admissionData = data;
      uniCombobox.setItems(data.universities);
      loadingEl.classList.add('hidden');
      formEl.classList.remove('hidden');
      emptyEl.classList.remove('hidden');
    } catch (err) {
      loadingEl.classList.add('hidden');
      errorEl.textContent = err instanceof Error ? err.message : '데이터 로드 실패';
      errorEl.classList.remove('hidden');
    }
  }

  function scheduleAdmissionPrefetch(): void {
    const run = () => {
      void getAdmissionLib().then((lib) => lib.prefetchAdmissionIndex());
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(run, { timeout: 5000 });
    } else {
      setTimeout(run, 3000);
    }
  }

  async function goToStep(step: WizardStep) {
    currentStep = step;
    wizardPanels.forEach((panel) => {
      panel.classList.toggle('hidden', parseInt(panel.dataset.step!, 10) !== step);
    });
    progressFill.style.width = `${(step / 4) * 100}%`;
    stepLabel.textContent = `${step} / 4 · ${getStepLabel(step)}`;
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (step >= 3) updateConverter();
    if (step === 4) {
      updateGradeSummary();
      await ensureAdmissionData();
    }
    syncUrl(step);
    updateWizardNav();
  }

  function getSharePayload() {
    if (!lastResult) throw new Error('no result');
    const semesterLabel = getSemesterLabel();
    const grade5 = lastResult.grade5.toFixed(3);
    const grade9 = lastResult.grade9.toFixed(3);
    const percentile = lastResult.percentile.toFixed(3);
    const tier = getPercentileTier(lastResult.percentile);
    const url = buildShareUrl({
      step: 4,
      semester: getSelectedSemester(),
      grade5,
      grade9,
    });
    const text = buildShareText({ semesterLabel, grade5, grade9, percentile, tier });
    return { semesterLabel, grade5, grade9, percentile, tier, url, text };
  }

  function stepGrade(input: HTMLInputElement, delta: number) {
    const current = parseFloat(input.value);
    const base = Number.isFinite(current) ? current : parseFloat(input.min);
    formatGradeValue(input, base + delta);
    updateWizardNav();
  }

  function resetAdmissionSelection() {
    deptCombobox.clear();
    deptCombobox.setItems([]);
    deptCombobox.setEnabled(false);
    resultsEl.innerHTML = '';
    resultsEl.classList.add('hidden');
    emptyEl.textContent = '모집단위를 선택하면 전형·세부전형별 입결을 표시합니다.';
    emptyEl.classList.remove('hidden');
  }

  function getMyGrade9(): number | null {
    const val = parseFloat(grade9Input.value);
    return Number.isFinite(val) ? val : null;
  }

  function onUniChange() {
    if (!admissionData || !admissionLib || !uniCombobox.getValue()) {
      resetAdmissionSelection();
      return;
    }

    deptCombobox.setItems(admissionLib.getDepartmentsForUniversity(admissionData, uniCombobox.getValue()));
    deptCombobox.setEnabled(true);
    deptCombobox.clear();
    resultsEl.innerHTML = '';
    resultsEl.classList.add('hidden');
    emptyEl.classList.remove('hidden');
  }

  function buildCompareHtml(cuts: YearCut[], myGrade: number | null): string {
    if (myGrade === null) return '';

    const latest = cuts.find((row) => row.c !== null);
    if (latest?.c === null || latest?.c === undefined) return '';

    const diff = myGrade - latest.c;
    const text =
      diff <= 0
        ? `입력하신 <strong>9등급 ${myGrade.toFixed(3)}</strong>은(는) ${latest.y}학년도 <strong>70% 컷 ${latest.c.toFixed(2)}</strong> 기준 <strong>합격권 안쪽</strong>입니다.`
        : `입력하신 <strong>9등급 ${myGrade.toFixed(3)}</strong>은(는) ${latest.y}학년도 <strong>70% 컷 ${latest.c.toFixed(2)}</strong>보다 <strong>${diff.toFixed(3)} 등급</strong> 높습니다.`;

    return `<p class="compare-verdict">${text}</p>`;
  }

  function renderCutsTable(cuts: YearCut[], myGrade: number | null): string {
    const rows = cuts
      .map((row) => {
        const cutText = row.c === null ? '—' : row.c.toFixed(2);
        let rowClass = '';
        if (myGrade !== null && row.c !== null) {
          rowClass = myGrade <= row.c ? 'row-pass' : 'row-fail';
        }
        return `<tr class="${rowClass}">
          <td class="font-medium text-[#f0ece4]">${row.y}</td>
          <td class="result-value cut-value">${cutText}</td>
          <td class="text-[#c4c0b8]">${row.q ?? '—'}</td>
          <td class="text-[#c4c0b8]">${row.r !== null ? row.r.toFixed(2) : '—'}</td>
        </tr>`;
      })
      .join('');

    return `<div class="premium-table-wrap">
      <table class="premium-table w-full min-w-[320px]">
        <thead>
          <tr>
            <th>대입연도</th>
            <th>교과 70% 컷</th>
            <th>모집인원</th>
            <th>경쟁률</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
  }

  function renderAdmissionResults() {
    if (!admissionData || !admissionLib) return;

    const uni = uniCombobox.getValue();
    const dept = deptCombobox.getValue();

    if (!uni || !dept) {
      resultsEl.innerHTML = '';
      resultsEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      return;
    }

    const routes = admissionLib.getRoutesForDepartment(admissionData, uni, dept);
    if (routes.length === 0) {
      resultsEl.innerHTML = '';
      resultsEl.classList.add('hidden');
      emptyEl.textContent = '해당 모집단위의 입결 데이터가 없습니다.';
      emptyEl.classList.remove('hidden');
      return;
    }

    const myGrade = getMyGrade9();
    resultsEl.innerHTML = routes
      .map(
        (route) => `<section class="admission-route-card">
          <div class="admission-route-header">
            <div class="admission-route-meta">
              <span class="admission-route-label">전형</span>
              <p class="admission-route-track">${route.track}</p>
            </div>
            <div class="admission-route-meta">
              <span class="admission-route-label">세부전형</span>
              <p class="admission-route-type">${route.typeName}</p>
            </div>
          </div>
          ${renderCutsTable(route.cuts, myGrade)}
          ${buildCompareHtml(route.cuts, myGrade)}
        </section>`,
      )
      .join('');

    emptyEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');
  }

  function restartWizard() {
    const defaultRadio = document.querySelector<HTMLInputElement>(
      `.semester-radio[value="${DEFAULT_SEMESTER_ID}"]`,
    );
    if (defaultRadio) defaultRadio.checked = true;

    const defaultMode = document.querySelector<HTMLInputElement>('.convert-mode-radio[value="5to9"]');
    if (defaultMode) defaultMode.checked = true;

    grade5Input.value = '';
    grade9Input.value = '';
    syncConversionModeUI();
    lastResult = null;

    uniCombobox.clear();
    resetAdmissionSelection();

    void goToStep(1);
    updateConverter();
    showToast('처음부터 다시 계산합니다.');
  }

  wizardPrev.addEventListener('click', () => {
    if (currentStep > 1) void goToStep((currentStep - 1) as WizardStep);
  });

  wizardNext.addEventListener('click', () => {
    if (currentStep === 2 && !canAdvanceFromStep2()) return;

    if (currentStep === 2) {
      const result = computeResult();
      if (!result) return;
      lastResult = result;
      applyResultToInputs(result);
    }

    if (currentStep < 4) void goToStep((currentStep + 1) as WizardStep);
  });

  document.getElementById('btn-download-card')?.addEventListener('click', () => {
    if (!lastResult) return;
    const p = getSharePayload();
    const canvas = renderResultCardCanvas({
      semesterLabel: p.semesterLabel,
      grade5: p.grade5,
      grade9: p.grade9,
      percentile: p.percentile,
      tier: p.tier,
    });
    downloadCanvas(canvas, `529cal-${p.grade9}.png`);
    showToast('결과 카드 이미지를 저장했습니다.');
  });

  async function handleShare(isAdmission: boolean) {
    if (!lastResult) return;
    const p = getSharePayload();
    const canvas = renderResultCardCanvas({
      semesterLabel: p.semesterLabel,
      grade5: p.grade5,
      grade9: p.grade9,
      percentile: p.percentile,
      tier: p.tier,
    });
    const shareText = isAdmission
      ? `${p.text}\n\n관심 대학 입결도 함께 확인해 보세요!`
      : p.text;
    const outcome = await shareCanvas(canvas, {
      title: '529Cal 내신 환산 결과',
      text: shareText,
      url: p.url,
    });
    if (outcome === 'shared') showToast('공유 창을 열었습니다.');
    else if (outcome === 'copied') showToast('링크와 결과가 클립보드에 복사되었습니다.');
    else showToast('이미지를 저장했습니다. 직접 공유해 주세요.');
  }

  document.getElementById('btn-share-result')?.addEventListener('click', () => handleShare(false));

  document.getElementById('btn-share-admission')?.addEventListener('click', async () => {
    const outcome = await shareSite();
    if (outcome === 'shared') showToast('529Cal 링크를 공유했습니다.');
    else if (outcome === 'unsupported') showToast('이 브라우저에서는 공유를 지원하지 않습니다. 모바일에서 이용해 주세요.');
  });

  document.getElementById('btn-restart-wizard')?.addEventListener('click', restartWizard);

  convertModeRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      syncConversionModeUI();
      updateWizardNav();
    });
  });

  semesterRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      updateConverter();
      updateWizardNav();
    });
  });
  grade5Input.addEventListener('input', () => {
    updateWizardNav();
  });
  grade9Input.addEventListener('input', () => {
    updateWizardNav();
  });
  grade5Input.addEventListener('blur', () => {
    const v = parseFloat(grade5Input.value);
    if (Number.isFinite(v)) formatGradeValue(grade5Input, v);
  });
  grade9Input.addEventListener('blur', () => {
    const v = parseFloat(grade9Input.value);
    if (Number.isFinite(v)) formatGradeValue(grade9Input, v);
  });
  gradeStepButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const dir = btn.getAttribute('data-dir');
      if (!targetId || !dir) return;
      stepGrade(document.getElementById(targetId) as HTMLInputElement, dir === 'up' ? GRADE_STEP : -GRADE_STEP);
    });
  });

  scheduleAdmissionPrefetch();

  function restoreFromUrl() {
    const state = parseWizardState(window.location.search);
    if (state.semester) {
      const radio = document.querySelector<HTMLInputElement>(`.semester-radio[value="${state.semester}"]`);
      if (radio) radio.checked = true;
    }
    if (state.grade5) grade5Input.value = state.grade5;
    if (state.grade9) grade9Input.value = state.grade9;
    if (state.grade9 && !state.grade5) {
      const mode9to5 = document.querySelector<HTMLInputElement>('.convert-mode-radio[value="9to5"]');
      if (mode9to5) mode9to5.checked = true;
    }
    syncConversionModeUI();
    if (state.step && state.step >= 3) updateConverter();
    if (state.step) void goToStep(state.step);
  }

  syncConversionModeUI();
  restoreFromUrl();
  updateWizardNav();
</script>
